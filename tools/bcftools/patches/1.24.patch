diff --git a/Makefile b/Makefile
index 8ce191c2..f5cf4930 100644
--- a/Makefile
+++ b/Makefile
@@ -117,7 +117,7 @@ PACKAGE_VERSION = 1.24
 # $(shell), :=, etc are GNU Make-specific.  If you don't have GNU Make,
 # comment out this conditional.
 ifneq "$(wildcard .git)" ""
-PACKAGE_VERSION := $(shell git describe --always --dirty)
+PACKAGE_VERSION := $(shell git describe --always)
 DOC_VERSION :=  $(shell git describe --always)+
 DOC_DATE := $(shell date +'%Y-%m-%d %R %Z')
 
@@ -229,7 +229,7 @@ test check: test-no-plugins
 endif  # PLUGINS_ENABLED
 
 bcftools: $(OBJS) $(HTSLIB)
-	$(CC) $(DYNAMIC_FLAGS) $(ALL_LDFLAGS) -o $@ $(OBJS) $(HTSLIB_LIB) -lm $(ALL_LIBS) $(GSL_LIBS) $(PERL_LIBS) -lpthread
+	$(CC) $(DYNAMIC_FLAGS) $(ALL_LDFLAGS) -o ../build/$@.mjs $(OBJS) $(HTSLIB_LIB) -lm $(ALL_LIBS) $(GSL_LIBS) $(PERL_LIBS)
 
 plugins: $(PLUGINS)
 
diff --git a/version.sh b/version.sh
index 72b2e5bc..fe48abed 100755
--- a/version.sh
+++ b/version.sh
@@ -30,7 +30,7 @@ VERSION=1.24
 if [ -e .git ]
 then
     # If we ever get to 10.x this will need to be more liberal
-    VERSION=`git describe --match '[0-9].[0-9]*' --dirty --always`
+    VERSION=`git describe --match '[0-9].[0-9]*' --always`
 fi
 
 echo $VERSION
